{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/tooling/hooks/scripts/session_start_context.sh",
            "statusMessage": "Loading hook policy"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/tooling/hooks/scripts/pre_tool_guard.sh",
            "statusMessage": "Checking command policy"
          }
        ]
      }
    ]
  }
}
