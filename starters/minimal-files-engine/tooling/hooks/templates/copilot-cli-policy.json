{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "../../tooling/hooks/scripts/session_start_context.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "../../tooling/hooks/scripts/log_prompt.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "../../tooling/hooks/scripts/pre_tool_guard.sh",
        "cwd": ".github/hooks",
        "timeoutSec": 15
      }
    ]
  }
}
