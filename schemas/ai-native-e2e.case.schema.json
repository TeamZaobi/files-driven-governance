{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://files-driven.dev/schemas/ai-native-e2e.case.schema.json",
  "title": "AI Native E2E Case Contract",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "family",
    "version_anchor",
    "title",
    "scenario_kind",
    "adapter_ref",
    "scope_context",
    "input_dialogue",
    "expected_assertions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "family": {
      "const": "ai_native_e2e_case"
    },
    "version_anchor": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "scenario_kind": {
      "type": "string",
      "enum": [
        "conversation_replay",
        "replay",
        "stress",
        "regression"
      ]
    },
    "adapter_ref": {
      "type": "string"
    },
    "scope_context": {
      "type": "object",
      "required": [
        "capability_scope",
        "project_scope",
        "runtime_scope"
      ],
      "properties": {
        "capability_scope": {
          "type": "string",
          "minLength": 1
        },
        "project_scope": {
          "type": "string",
          "minLength": 1
        },
        "runtime_scope": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "input_dialogue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "turn_id",
          "role",
          "content"
        ],
        "properties": {
          "turn_id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user",
              "assistant",
              "tool"
            ]
          },
          "content": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string"
          },
          "tool_call_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "expected_assertions": {
      "type": "object",
      "required": [
        "route_assertions",
        "read_assertions",
        "write_assertions",
        "boundary_assertions",
        "projection_assertions",
        "recovery_assertions",
        "trajectory_assertions"
      ],
      "properties": {
        "route_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "read_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "write_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "projection_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recovery_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "trajectory_assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
