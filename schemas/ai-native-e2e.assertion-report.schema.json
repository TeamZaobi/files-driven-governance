{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://files-driven.dev/schemas/ai-native-e2e.assertion-report.schema.json",
  "title": "AI Native E2E Assertion Report Contract",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "family",
    "version_anchor",
    "case_ref",
    "replay_artifact_ref",
    "run_ref",
    "overall_status",
    "assertions",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "report_id": {
      "type": "string"
    },
    "family": {
      "const": "ai_native_e2e_assertion_report"
    },
    "version_anchor": {
      "type": "string"
    },
    "case_ref": {
      "type": "string"
    },
    "replay_artifact_ref": {
      "type": "string"
    },
    "run_ref": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "assertion_id",
          "category",
          "status",
          "expected",
          "actual",
          "evidence_refs"
        ],
        "properties": {
          "assertion_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "route",
              "read",
              "write",
              "boundary",
              "projection",
              "recovery",
              "trajectory"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "expected": {
            "type": "string",
            "minLength": 1
          },
          "actual": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
