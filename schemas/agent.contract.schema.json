{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://files-driven.dev/schemas/agent.contract.schema.json",
  "title": "Agent Contract",
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "family",
    "version_anchor",
    "roles"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "family": {
      "const": "agent"
    },
    "version_anchor": {
      "type": "string"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_id"
        ],
        "properties": {
          "role_id": {
            "type": "string"
          },
          "can_execute_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "can_review_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "can_approve_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "blocked_action_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
