{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://files-driven.dev/schemas/ai-native-e2e.adapter-contract.schema.json",
  "title": "AI Native E2E Adapter Contract",
  "type": "object",
  "required": [
    "schema_version",
    "adapter_id",
    "family",
    "version_anchor",
    "name",
    "entrypoint",
    "execution_model",
    "supported_scenarios",
    "emitted_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "adapter_id": {
      "type": "string"
    },
    "family": {
      "const": "ai_native_e2e_adapter"
    },
    "version_anchor": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "execution_model": {
      "type": "string",
      "enum": [
        "subprocess",
        "api",
        "hybrid"
      ]
    },
    "supported_scenarios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "conversation_replay",
          "replay",
          "stress",
          "regression"
        ]
      }
    },
    "emitted_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "run_metadata",
          "replay_artifact",
          "assertion_report",
          "transcript",
          "workspace_diff"
        ]
      }
    },
    "input_contracts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "output_contracts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
